# Database Configuration
# Replace with your actual PostgreSQL connection details
DATABASE_URL=postgresql+asyncpg://bookly_user:your_password@localhost:5432/bookly_db

# JWT Configuration
# IMPORTANT: Generate a secure secret key for production
# You can generate one using: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-super-secure-secret-key-change-this-in-production
JWT_ALGORITHM=HS256

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Optional: Uncomment and set if your Redis server requires authentication
# REDIS_PASSWORD=your-redis-password

# Optional: Set if you want to use a different Redis database number
# REDIS_DB=0